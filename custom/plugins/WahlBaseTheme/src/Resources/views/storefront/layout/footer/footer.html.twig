{% sw_extends '@Storefront/storefront/layout/footer/footer.html.twig' %}

{% block layout_footer_navigation %}
    <div
            id="footerColumns"
                class="row footer-columns"
                data-collapse-footer-columns="true"
                role="list"
    >
            {% block layout_footer_payment_logos %}
                <div class="col-md-3 footer-column js-footer-column">

                    {% block layout_footer_navigation_logo_payment %}
                        <div class="footer-column-headline footer-headline js-footer-column-headline js-collapse-footer-column-trigger"
                             id="collapseFooterLogoPaymentTitle"
                             aria-expanded="true"
                             aria-controls="collapseFooterLogoPayment"
                             role="listitem">
                            {{ "wahl.footer.title.payment"|trans|sw_sanitize }}
                            {% block layout_footer_logo_payment_icons %}
                                <button class="footer-column-toggle btn btn-link btn-link-inline js-collapse-footer-column-trigger"
                                        data-bs-target="#collapseFooterLogoPayment"
                                        data-bs-toggle="collapse"
                                        aria-controls="collapseFooterLogoPayment"
                                        aria-labelledby="collapseFooterLogoPaymentTitle"
                                        aria-expanded="true">

                                    {% sw_icon 'plus' style { class: 'footer-plus' } %}
                                    {% sw_icon 'minus' style { class: 'footer-minus' } %}
                                </button>
                            {% endblock %}
                        </div>
                    {% endblock %}

                    <div id="collapseFooterLogoPayment"
                         class="footer-column-content-inner footer-column-content collapse js-footer-column-content"
                         aria-labelledby="collapseFooterLogoPaymentTitle">
                        <div class="d-flex gap-3">
                            {#% for paymentMethod in page.salesChannelPaymentMethods % REPLACED_FOR_NEW_SW_VERSION #}
                            {% for paymentMethod in footer.paymentMethods %}
                                {% block layout_footer_payment_logo %}
                                    {% if paymentMethod.media %}
                                        <div class="footer-logo is-payment">
                                            {% sw_thumbnails 'footer-payment-image-thumbnails' with {
                                                media: paymentMethod.media,
                                                sizes: {
                                                    'default': '100px'
                                                },
                                                attributes: {
                                                    'class': 'img-fluid footer-logo-image',
                                                    'alt': (paymentMethod.media.translated.alt ?: paymentMethod.translated.name),
                                                    'title': (paymentMethod.media.translated.title ?: paymentMethod.translated.name)
                                                }
                                            } %}
                                        </div>
                                    {% endif %}
                                {% endblock %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endblock %}

            {% block layout_footer_shipping_logos %}

                <div class="col-md-3 footer-column js-footer-column">

                    {% block layout_footer_navigation_logo_shipping %}
                        <div class="footer-column-headline footer-headline js-footer-column-headline js-collapse-footer-column-trigger"
                             id="collapseFooterLogoShippingTitle"
                             aria-expanded="true"
                             aria-controls="collapseFooterLogoShipping"
                             role="listitem">
                            {{ "wahl.footer.title.shipping"|trans|sw_sanitize }}
                            {% block layout_footer_logo_shipping_icons %}
                                <button class="footer-column-toggle btn btn-link btn-link-inline js-collapse-footer-column-trigger"
                                        data-bs-target="#collapseFooterLogoShipping"
                                        data-bs-toggle="collapse"
                                        aria-controls="collapseFooterLogoShipping"
                                        aria-labelledby="collapseFooterLogoShippingTitle"
                                        aria-expanded="true">

                                    {% sw_icon 'plus' style { class: 'footer-plus' } %}
                                    {% sw_icon 'minus' style { class: 'footer-minus' } %}
                                </button>
                            {% endblock %}
                        </div>
                    {% endblock %}

                    <div id="collapseFooterLogoShipping"
                         class="footer-column-content footer-column-content-inner collapse js-footer-column-content"
                         aria-labelledby="collapseFooterLogoShippingTitle">
                        <div class="d-flex gap-3">
                            {{ "wahl.footer.shipping.content"|trans|raw }}
                        </div>
                    </div>
                </div>
            {% endblock %}


        {% block layout_footer_navigation_hotline %}
        {% endblock %}

        {% block layout_footer_navigation_columns %}
            {#% for root in page.footer.navigation.tree % REPLACED_FOR_NEW_SW_VERSION #}
            {% for root in footer.navigation.tree %}
                {% block layout_footer_navigation_column %}

                    {% set menuOrder = (root.index|length) %}

                    <div class="col-md-3 footer-column order-{{ loop.index }} js-footer-column">
                        {% block layout_footer_navigation_information_headline %}
                            <div class="footer-column-headline footer-headline js-collapse-footer-column-trigger"
                                 id="collapseFooterTitle{{ loop.index }}"
                                 data-bs-target="#collapseFooter{{ loop.index }}"
                                 aria-expanded="true"
                                 aria-controls="collapseFooter{{ loop.index }}">

                                {% if root.category.type == 'folder' %}
                                    {{ root.category.translated.name }}
                                {% else %}
                                    <a href="{{ category_url(root.category) }}"
                                       {% if category_linknewtab(root.category) %}target="_blank"{% endif %}
                                       title="{{ root.category.translated.name }}">
                                        {{ root.category.translated.name }}
                                    </a>
                                {% endif %}
                                {% block layout_footer_navigation_information_icons %}
                                    <button class="footer-column-toggle btn btn-link btn-link-inline js-collapse-footer-column-trigger"
                                            data-bs-target="#collapseFooter{{ loop.index }}"
                                            data-bs-toggle="collapse"
                                            aria-controls="collapseFooter{{ loop.index }}"
                                            aria-labelledby="collapseFooterTitle{{ loop.index }}"
                                            aria-expanded="true">

                                        {% sw_icon 'plus' style { class: 'footer-plus' } %}
                                        {% sw_icon 'minus' style { class: 'footer-minus' } %}
                                    </button>
                                {% endblock %}
                            </div>
                        {% endblock %}

                        {% block layout_footer_navigation_information_content %}
                            <div id="collapseFooter{{ loop.index }}"
                                 class="footer-column-content collapse js-footer-column-content"
                                 aria-labelledby="collapseFooterTitle{{ loop.index }}">
                                <div class="footer-column-content-inner">
                                    {% block layout_footer_navigation_information_links %}
                                        <ul class="list-unstyled">
                                            {% for treeItem in root.children %}
                                                {% set category = treeItem.category %}
                                                {% set name = category.translated.name %}

                                                {% block layout_footer_navigation_information_link_item %}
                                                    <li class="footer-link-item">
                                                        {% block layout_footer_navigation_information_link %}
                                                            {% if category.type == 'folder' %}
                                                                <div>{{ name }}</div>
                                                            {% else %}
                                                                <a class="footer-link"
                                                                   href="{{ category_url(category) }}"
                                                                   {% if category_linknewtab(category) %}target="_blank"{% endif %}
                                                                   title="{{ name }}">
                                                                    {{ name }}
                                                                </a>
                                                            {% endif %}
                                                        {% endblock %}
                                                    </li>
                                                {% endblock %}
                                            {% endfor %}
                                        </ul>
                                    {% endblock %}
                                </div>
                            </div>
                        {% endblock %}
                    </div>
                {% endblock %}
            {% endfor %}
        {% endblock %}
    </div>
{% endblock %}

{% block layout_footer_payment_shipping_logos %}{% endblock %}

{% block layout_footer_bottom %}
    <div class="footer-bottom p-3">
        {% block layout_footer_service_menu %}{% endblock %}

        <div class="container">
            <div class="row m-0">
                <div class="col-md-2">
                    {% sw_include '@Storefront/storefront/layout/header/logo.html.twig' %}
                </div>
                <div class="col-md-10 d-flex align-items-center justify-content-end">
                    {% block layout_footer_vat %}
                        {% if showVatNotice or showVatNotice is not defined %}
                            <div class="footer-vat">
                                {% if context.taxState == "gross" %}
                                    <span>
                                        {{ "footer.includeVatText"|trans({
                                            '%url%': path('frontend.cms.page', { id: config('core.basicInformation.shippingPaymentInfoPage') }),'%star%': '*'
                                        })|raw }}
                                    </span>
                                {% else %}
                                    <span>x2
                                        {{ "footer.excludeVatText"|trans({
                                            '%url%': path('frontend.cms.page', { id: config('core.basicInformation.shippingPaymentInfoPage') }),'%star%': '*'
                                        })|raw }}
                                    </span>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% endblock %}
                </div>
            </div>
        </div>



        {% block layout_footer_copyright %}{% endblock %}
    </div>
{% endblock %}