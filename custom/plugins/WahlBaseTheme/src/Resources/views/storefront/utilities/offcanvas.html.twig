{% sw_extends '@Storefront/storefront/utilities/offcanvas.html.twig' %}

{% block utilities_offcanvas_header %}
    <div class="offcanvas-header offcanvas-header-custom d-flex align-items-center">
        {% block utilities_offcanvas_left %}
            <div class="offcanvas-header-left flex-grow-1 d-flex align-items-center p-3">
                {% block utilities_offcanvas_left_content %}
                    <strong>{{ 'wahl.offcanvas.header.menu'|trans|sw_sanitize}}</strong>
                {% endblock %}
            </div>
        {% endblock %}

        <div class="offcanvas-header-right flex-shrink-0">
            {% block utilities_offcanvas_close %}
                <button
                    class="btn offcanvas-close js-offcanvas-close offcanvas-close-icon-only"
                    type="button"
                    aria-label="{{ 'general.offcanvasCloseMenu'|trans|sw_sanitize }}"
                >
                    {% block utilities_offcanvas_close_icon %}
                        {% sw_icon 'x' style { size: 'sm' } %}
                    {% endblock %}

                    {% block utilities_offcanvas_close_text %}
                        {# empty #}
                    {% endblock %}
                </button>
            {% endblock %}
        </div>
    </div>
{% endblock %}
